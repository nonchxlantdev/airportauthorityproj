VITE_SUPABASE_URL=https://hnwgqvoybzmsdqbpngjx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --- Offline map (Android PWA, optional until map module is wired) ---
# Tile URL template with {z}/{x}/{y} placeholders, e.g. https://tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_TILE_URL_TEMPLATE=
# Workbox stale-while-revalidate regexes (match your provider URLs at build time)
VITE_MAP_TILE_URL_REGEX=
VITE_MAP_STYLE_URL=
VITE_MAP_STYLE_URL_REGEX=
VITE_MAP_GLYPHS_URL_REGEX=
# Philip S. W. Goldson Int'l Airport bounding box (decimal degrees)
VITE_MAP_BOUNDS_NORTH=
VITE_MAP_BOUNDS_SOUTH=
VITE_MAP_BOUNDS_EAST=
VITE_MAP_BOUNDS_WEST=
VITE_MAP_MIN_ZOOM=14
VITE_MAP_MAX_ZOOM=18

# Optional: Supabase table for staff last-known GPS (read-only offline cache + offline ping queue)
# Create with supabase/staff_positions.sql, then set:
VITE_STAFF_POSITIONS_TABLE=staff_positions
